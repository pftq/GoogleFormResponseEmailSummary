function onFormSubmit(e) {
  var spreadsheet = e.source;
  var form = FormApp.openByUrl(spreadsheet.getFormUrl());
  
  var formTitle = form.getTitle();
  var responses = e.namedValues;

// requires permissioning from first failed run - hardcode "youremail@domain.com" if you want to skip that
  var recipient = Session.getEffectiveUser().getEmail(); 
  var subject = "New Response: " + formTitle;

  var submitterEmail = "";
  var possibleEmailKeys = ["Email", "Email Address", "Email address", "Your Email"];
  for (var i = 0; i < possibleEmailKeys.length; i++) {
    if (responses[possibleEmailKeys[i]] && responses[possibleEmailKeys[i]][0]) {
      submitterEmail = responses[possibleEmailKeys[i]][0];
      break;
    }
  }

  var submitterName = responses["Name"] ? responses["Name"][0] : 
                      responses["Full Name"] ? responses["Full Name"][0] : 
                      responses["Your Name"] ? responses["Your Name"][0] : "";

  // Build HTML email
  var htmlBody = "<h2>New response submitted to: " + formTitle + "</h2>";
  htmlBody += "<p><strong>Submitted:</strong> " + new Date() + "</p>";

  if (submitterEmail) {
    htmlBody += "<p><strong>Submitted by:</strong> " + submitterEmail + "</p>";
  }
  if (submitterName) {
    htmlBody += "<p><strong>Name:</strong> " + submitterName + "</p>";
  }

  htmlBody += "<hr>";

  for (var question in responses) {
    var answer = responses[question] && responses[question][0] ? responses[question][0] : "";
    
    if (question.toLowerCase().includes("email") || question.toLowerCase().includes("name")) {
      continue;
    }
    
    htmlBody += "<p><strong>" + question + "</strong><br>" + answer + "</p>";
  }

  htmlBody += "<hr>";
  htmlBody += "<p><a href='" + form.getPublishedUrl() + "'>View the form</a></p>";

  GmailApp.sendEmail(recipient, subject, "Plain text version", {
    htmlBody: htmlBody
  });
}
