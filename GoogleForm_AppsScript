function onFormSubmit(e) {

  // requires failure and granting permission initially - optionally hardcode "your_email@domain.com" to skip that
  var recipient = Session.getEffectiveUser().getEmail();

  var sheet = e.source.getActiveSheet();

  sheet.sort(1, false); // false = descending (newest first)
  
  var headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
  var values = sheet.getRange(2, 1, 1, sheet.getLastColumn()).getValues()[0]; // Always read row 2

  var form = FormApp.openByUrl(sheet.getFormUrl());
  var formTitle = form.getTitle();


  var subject = "New Response: " + formTitle;

  // Build clean email body
  var htmlBody = "<h2>New response submitted to: " + formTitle + "</h2>";
  htmlBody += "<p><strong>Submitted:</strong> " + new Date() + "</p>";
  htmlBody += "<hr>";

  for (var i = 0; i < headers.length; i++) {
    var header = headers[i];
    var value = values[i] || "";
    htmlBody += "<p><strong>" + header + "</strong><br>" + value + "</p>";
  }

  htmlBody += "<hr>";
  htmlBody += "<p><a href='" + form.getPublishedUrl() + "'>View the form</a></p>";

  GmailApp.sendEmail(recipient, subject, "Plain text version", {
    htmlBody: htmlBody
  });
}
